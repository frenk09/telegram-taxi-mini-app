{
  "name": "telegram-taxi-mini-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs ./apps/api/src/index.ts",
    "dev:mini": "node --env-file=.env ./node_modules/vite/bin/vite.js ./apps/mini-app",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
